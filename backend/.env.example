# ─── LLM ────────────────────────────────────────
# local = Xinference / LM Studio (OpenAI-compatible)
# huggingface = HF Inference Router + gpt-oss-20b (https://huggingface.co/openai/gpt-oss-20b)
LLM_BACKEND=local
LLM_BASE_URL=http://localhost:9997/v1
LLM_MODEL=qwen2.5-instruct
LLM_API_KEY=not-needed

# Khi LLM_BACKEND=huggingface — đặt token tại https://huggingface.co/settings/tokens (không commit .env)
# HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
# LLM_MODEL=openai/gpt-oss-20b
# HF_TOKEN=hf_your_token_here

EMBED_BASE_URL=http://localhost:9997/v1
EMBED_MODEL=bge-m3
EMBED_DIMS=1024

RERANK_BASE_URL=http://localhost:9997/v1
RERANK_MODEL=bge-reranker-v2-m3

# ─── Elasticsearch ──────────────────────────────
ES_URL=http://localhost:9200
ES_INDEX=gem_hr_docs
# true chỉ khi cluster có license hỗ trợ RRF (thường để false)
ES_USE_RRF=false

# ─── PostgreSQL ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gemhr:gemhr2026@localhost:5432/gem_hr_copilot
POSTGRES_PASSWORD=gemhr2026

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Confluence ─────────────────────────────────
# Cloud: CONFLUENCE_CLOUD=true, TOKEN = API token (id.atlassian.net)
# Server/Data Center: CONFLUENCE_CLOUD=false, TOKEN hoặc PASSWORD = mật khẩu đăng nhập hoặc PAT
# URL phải trùng base khi mở Confluence (nhiều site dùng hậu tố /wiki)
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_CLOUD=true
CONFLUENCE_USER=
CONFLUENCE_TOKEN=
CONFLUENCE_PASSWORD=

# ─── App ─────────────────────────────────────────
APP_NAME=GEM HR Copilot Pro
DEBUG=false
PUBLIC_API_BASE=http://localhost:8000
DOCUMENT_STORAGE_DIR=data/uploaded_documents
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

RERANK_MIN_SCORE=0.32
RETRIEVAL_MIN_SCORE=0.2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
PROCESS_GUIDE_MODE=rag_fallback
WORKFLOWS_JSON_PATH=data/sample_workflows.gem.json
