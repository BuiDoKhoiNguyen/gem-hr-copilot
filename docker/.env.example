# ─── Database Configuration ────────────────────────────────────────────────
POSTGRES_DB=hr_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Elasticsearch Configuration ───────────────────────────────────────────
ELASTICSEARCH_VERSION=8.14.3
ES_HOST=elasticsearch
ES_PORT=9200
ES_JAVA_OPTS=-Xms1g -Xmx1g
ES_SECURITY_ENABLED=false

# ─── Redis Configuration ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Backend Service Configuration ────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_IMAGE=gem-hr-copilot-backend:latest

# ─── Frontend Service Configuration ───────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://backend:8000

# ─── Service URLs (for Docker networking) ──────────────────────────────────
ES_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379

# ─── Cloud LLM Services (OpenAI-compatible APIs) ───────────────────────────
# 🔑 REQUIRED: Replace with your actual API credentials

# Chat LLM (OpenAI, Azure OpenAI, or compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# Embedding Model (OpenAI or compatible)
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small

# Reranker Model (Jina AI, Cohere, or compatible)
RERANK_BASE_URL=https://api.jina.ai/v1
RERANK_MODEL=jina-reranker-v2-base-multilingual

# ─── Alternative Cloud Providers Examples ─────────────────────────────────
#
# Azure OpenAI:
# LLM_BASE_URL=https://your-resource.openai.azure.com/
# LLM_API_KEY=your_azure_openai_key
# LLM_MODEL=gpt-4o-mini
#
# Cohere Reranker:
# RERANK_BASE_URL=https://api.cohere.ai/v1
# RERANK_MODEL=rerank-multilingual-v3.0
#
# Anthropic Claude (if supported):
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-3-5-haiku-20241022

# ─── Nginx Configuration ───────────────────────────────────────────────────
NGINX_PORT=80
HTTPS_PORT=443

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO